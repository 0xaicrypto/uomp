<div class="window-wrap">
  <div class="window">
    <div class="window-bar">
      <div class="window-dots">
        <div class="window-dot r"></div>
        <div class="window-dot y"></div>
        <div class="window-dot g"></div>
      </div>
    </div>
    <div class="window-body" id="terminal-demo" style="padding:20px; font-family:monospace; font-size:0.82rem; color:#D1D5DB; text-align:left; min-height:160px; max-height:200px; overflow-y:auto; line-height:1.7;">
    </div>
  </div>
  <div class="stats-bar">
    <div class="stat-item"><span class="stat-val">本地优先</span><span class="stat-lbl">数据保留在用户设备</span></div>
    <div class="stat-item"><span class="stat-val">最小授权</span><span class="stat-lbl">按 tag / key / field 控制</span></div>
    <div class="stat-item"><span class="stat-val">远程安全</span><span class="stat-lbl">mTLS Gateway + 聚合查询</span></div>
    <div class="stat-item"><span class="stat-val">透明保留</span><span class="stat-lbl">Agent 声明数据删除策略</span></div>
    <div class="stat-item"><span class="stat-val">可审计</span><span class="stat-lbl">每次访问记录日志</span></div>
  </div>
</div>

<script>
(function() {
  const el = document.getElementById('terminal-demo');
  const C = { g: '#9CA3AF', b: '#60A5FA', w: '#F9FAFB', gn: '#34D399', dim: '#6B7280' };
  const cursor = '<span style="animation:blink 1s step-end infinite">▌</span>';

  const frames = [
    `<span style="color:${C.g}">$</span> <span style="color:${C.w}">uomp import holdings.csv</span><br><span style="color:${C.gn}">✓ 10 items</span><br>`,
    `<span style="color:${C.g}">$</span> <span style="color:${C.w}">uomp authorize stock-analyst</span><br><span style="color:${C.gn}">✓ token</span><br>`,
    `<span style="color:${C.g}">$</span> <span style="color:${C.w}">node index.js</span><br><span style="color:${C.g}">P&amp;L: +72% &nbsp;Sharpe: 1.24 &nbsp;Signals: 8</span><br><span style="color:${C.gn}">✓ report.html</span><br>`,
    `<span style="color:${C.g}">$</span> <span style="color:${C.w}">uomp gateway start</span><br><span style="color:${C.dim}">https://xxx.trycloudflare.com</span><br>`,
  ];

  let i = 0;
  let cycle = 0;
  const maxCycles = 3;

  function scroll() { el.scrollTop = el.scrollHeight; }

  async function next() {
    el.innerHTML += frames[i];
    scroll();
    await new Promise(r => setTimeout(r, 1800));
    i++;
    if (i >= frames.length) {
      i = 0;
      cycle++;
      if (cycle >= maxCycles) {
        await new Promise(r => setTimeout(r, 2000));
        el.innerHTML = '';
        cycle = 0;
        await new Promise(r => setTimeout(r, 400));
      }
    }
    next();
  }

  el.innerHTML = `<span style="color:${C.dim}">UOMP v1.0</span><br><br>`;
  next();
})();
</script>
<style>
  @keyframes blink { 50% { opacity: 0; } }
  #terminal-demo::-webkit-scrollbar { width: 4px; }
  #terminal-demo::-webkit-scrollbar-track { background: #111; }
  #terminal-demo::-webkit-scrollbar-thumb { background: #333; }
</style>
